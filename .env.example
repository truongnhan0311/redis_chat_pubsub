# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
CHAT_REDIS_ADDR=localhost:6379
CHAT_REDIS_PASSWORD=
CHAT_REDIS_DB=5

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
# Level:  debug | info | warn | error
CHAT_LOG_LEVEL=info
# Format: text | json
CHAT_LOG_FORMAT=json

# ─────────────────────────────────────────────────────────────────────────────
# Server (used by example/main.go)
# ─────────────────────────────────────────────────────────────────────────────
CHAT_SERVER_ADDR=:8080

# ─────────────────────────────────────────────────────────────────────────────
# API Keys (server-to-server authentication)
# ─────────────────────────────────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Sent via:  X-API-Key: <key>  header  OR  ?api_key=<key>  query param.
# Leave empty = no auth (dev only — NEVER in production).
CHAT_API_KEYS=your-secret-key-1,your-secret-key-2
