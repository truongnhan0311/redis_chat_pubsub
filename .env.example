# ─────────────────────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────────────────────
CHAT_REDIS_ADDR=localhost:6379
CHAT_REDIS_PASSWORD=
CHAT_REDIS_DB=0

# ─────────────────────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────────────────────
# Level:  debug | info | warn | error
CHAT_LOG_LEVEL=info
# Format: text | json
CHAT_LOG_FORMAT=text

# ─────────────────────────────────────────────────────────────────────────────
# Server (used by example/main.go)
# ─────────────────────────────────────────────────────────────────────────────
CHAT_SERVER_ADDR=:8080
